---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CTA from "@/components/sections/CTA.astro";
import PageIntro from "@/components/sections/PageIntro.astro";
import ServiceDetails from "@/components/sections/ServiceDetails.astro";
import PricingPackages from "@/components/sections/PricingPackages.astro";
import { siteConfig } from "@/config/site";
import { homePage } from "@/content/home";
import { servicePackages, servicesPage } from "@/content/site";
---

<BaseLayout
  title={`Layanan | ${siteConfig.name}`}
  description="Halaman layanan Ceels.id untuk membantu bisnis membangun ruang digital yang lebih jelas, rapi, dan meyakinkan."
>
  <Header />
  <main>
    <PageIntro {...servicesPage.intro} />
    <ServiceDetails offerings={servicesPage.offerings} approach={servicesPage.approach} />
    <PricingPackages
      detailed
      title={servicesPage.packagesIntro.title}
      description={servicesPage.packagesIntro.description}
      packages={servicePackages}
    />
    <CTA {...homePage.cta} />
  </main>
  <Footer />
</BaseLayout>
