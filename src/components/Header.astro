---
import { siteConfig } from "@/config/site";
import { Button } from "@/components/ui/button";
import { mainNavigation } from "@/content/site";

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  if (href.startsWith("/#")) return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-50 w-full border-b border-white/50 bg-background/65 backdrop-blur-xl supports-[backdrop-filter]:bg-background/55">
  <div class="container mx-auto flex items-center justify-between gap-3 px-4 py-3 md:gap-4 md:py-4">
    <a href="/" class="brand-lockup min-w-0">
      <img src="/logo.svg" alt={siteConfig.name} class="brand-mark" />
      <span class="truncate text-lg font-semibold tracking-[-0.04em] text-foreground sm:text-xl">{siteConfig.name}</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm md:flex">
      {mainNavigation.map((link) => (
        <a
          href={link.href}
          class={`font-medium tracking-[-0.01em] transition-colors hover:text-foreground ${isActive(link.href) ? "text-foreground" : "text-muted-foreground"}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 md:flex">
      <Button asChild>
        <a href="/#contact">Mari Diskusi</a>
      </Button>
    </div>

    <details class="group relative md:hidden">
      <summary class="soft-card flex h-10 w-10 shrink-0 cursor-pointer list-none items-center justify-center rounded-lg text-foreground marker:hidden">
        <span class="sr-only">Buka menu navigasi</span>
        <span class="flex flex-col gap-1.5">
          <span class="block h-0.5 w-4 bg-current"></span>
          <span class="block h-0.5 w-4 bg-current"></span>
          <span class="block h-0.5 w-4 bg-current"></span>
        </span>
      </summary>

      <div class="soft-card absolute right-0 top-[calc(100%+0.75rem)] w-[min(18rem,calc(100vw-2rem))] rounded-xl p-3 shadow-[0_18px_40px_rgba(18,22,14,0.08)]">
        <nav class="flex flex-col">
          {mainNavigation.map((link) => (
            <a
              href={link.href}
              class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-white/60 hover:text-foreground ${isActive(link.href) ? "text-foreground" : "text-muted-foreground"}`}
            >
              {link.label}
            </a>
          ))}
          <div class="mt-3 border-t border-border pt-3">
            <Button className="w-full" asChild>
              <a href="/#contact">Mari Diskusi</a>
            </Button>
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>
