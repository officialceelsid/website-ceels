---
import { Button } from "@/components/ui/button";

interface ServicePackage {
  name: string;
  price: string;
  promo: string;
  summary: string;
  highlights: readonly string[];
}

interface Props {
  title: string;
  description: string;
  packages: readonly ServicePackage[];
  detailed?: boolean;
  cta?: {
    label: string;
    href: string;
  };
}

const { title, description, packages, detailed = false, cta } = Astro.props;

const teaserPackages = packages.slice(0, 6);
const visiblePackages = detailed ? packages : teaserPackages;
---

<section id="packages" class="page-shell">
  <div class="site-stack">
    <div class={`${detailed ? "panel-dark" : "panel-light panel-outline"} section-frame`}>
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <p class={`display-eyebrow ${detailed ? "text-accent" : "text-primary/72"}`}>Paket Layanan</p>
          <h2 class={`section-title mt-4 ${detailed ? "text-white" : "text-primary"}`}>{title}</h2>
          <p class={`section-copy mt-5 max-w-2xl ${detailed ? "text-white/78" : "text-primary/78"}`}>{description}</p>
        </div>
        {cta && !detailed && (
          <a href={cta.href} class="section-link shrink-0">
            <span>{cta.label}</span>
            <span class="arrow-chip">↗</span>
          </a>
        )}
      </div>

      <div class={`mt-10 grid gap-4 md:mt-14 ${detailed ? "xl:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3"}`}>
        {visiblePackages.map((item, index) => (
          <article
            data-reveal
            data-reveal-delay={String(index * 70)}
            class={`${detailed ? "dark-card" : "soft-card"} flex h-full flex-col rounded-[2rem] ${detailed ? "p-6 md:p-7" : "p-5 md:p-6"}`}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class={`font-display uppercase leading-[0.92] tracking-[-0.04em] ${detailed ? "text-3xl text-white" : "text-[2rem] text-primary"}`}>{item.name}</p>
                <p class={`mt-3 font-semibold ${detailed ? "text-lg text-accent" : "text-base text-primary"}`}>{item.price}</p>
              </div>
              <span class={`rounded-full px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.06em] ${detailed ? "bg-accent text-primary" : "bg-primary text-white"}`}>
                {item.promo}
              </span>
            </div>

            <p class={`mt-4 ${detailed ? "text-sm leading-7 md:text-base text-white/76" : "text-sm leading-6 text-primary/72"}`}>{item.summary}</p>

            <ul class={`space-y-3 ${detailed ? "mt-6" : "mt-5"}`}>
              {item.highlights.slice(0, detailed ? item.highlights.length : 3).map((point) => (
                <li class={`flex gap-3 ${detailed ? "text-sm leading-6 md:text-base text-white/86" : "text-sm leading-6 text-primary/78"}`}>
                  <span class={`mt-2 h-2.5 w-2.5 shrink-0 rounded-full ${detailed ? "bg-accent" : "bg-primary"}`}></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>

            {detailed ? (
              <div class="mt-7 pt-2">
                <Button asChild>
                  <a href={`/#contact?paket=${encodeURIComponent(item.name)}`}>Diskusikan Paket Ini</a>
                </Button>
              </div>
            ) : (
              <div class="mt-6 pt-1">
                <a href="/services#packages" class="section-link text-base">
                  <span>Lihat detail paket</span>
                  <span class="arrow-chip h-9 w-9 text-base">↗</span>
                </a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
