---
import { Button } from "@/components/ui/button";

interface Props {
  title: string;
  description: string;
  primaryCta: {
    label: string;
    href: string;
  };
  secondaryCta: {
    label: string;
    href: string;
  };
  proof: {
    label: string;
    title: string;
    description: string;
    stats: readonly {
      value: string;
      label: string;
    }[];
  };
}

const { title, description, primaryCta, secondaryCta, proof } = Astro.props;
---

<section
  id="hero"
  class="grain-texture relative overflow-hidden px-4 py-8 md:px-6 md:py-16"
>
  <div
    class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_top_left,rgba(232,242,215,0.42),transparent_30%),radial-gradient(circle_at_76%_16%,rgba(139,197,63,0.08),transparent_22%),linear-gradient(180deg,rgba(255,255,255,0.92),rgba(251,251,248,0.92))]"
  >
  </div>
  <div
    class="absolute left-[-8rem] top-[8rem] -z-10 h-72 w-72 rounded-full bg-[#8bc53f]/8 blur-3xl"
  >
  </div>
  <div
    class="absolute right-[-6rem] top-[-2rem] -z-10 h-80 w-80 rounded-full bg-[#d8efab]/35 blur-3xl"
  >
  </div>
  <div
    class="absolute bottom-[-8rem] left-1/2 -z-10 h-80 w-80 -translate-x-1/2 rounded-full bg-[#b9df70]/8 blur-3xl"
  >
  </div>

  <div class="container mx-auto">
    <div
      data-reveal
      class="soft-surface grain-texture relative mx-auto overflow-hidden rounded-[1.25rem] px-5 py-9 sm:px-8 sm:py-12 md:px-12 md:py-16"
    >
      <div
        class="absolute inset-x-[12%] top-0 h-px bg-gradient-to-r from-transparent via-white/90 to-transparent"
      >
      </div>
      <div
        class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.84),transparent_58%)]"
      >
      </div>
      <div class="grid gap-7 lg:grid-cols-[1.2fr_0.8fr] lg:items-end lg:gap-0">
        <div class="max-w-4xl">
          <h1
            class="max-w-4xl text-[2.6rem] font-medium leading-[0.94] tracking-[-0.06em] text-balance sm:text-5xl md:text-6xl lg:text-8xl"
          >
            {title}
          </h1>
          <p
            class="mt-4 max-w-2xl text-[15px] leading-7 text-muted-foreground sm:mt-6 sm:text-lg sm:leading-8 md:mt-8 md:text-2xl"
          >
            {description}
          </p>
          <div
            class="mt-6 flex flex-col gap-3 sm:mt-8 sm:flex-row sm:gap-4 md:mt-10"
          >
            <Button size="lg" asChild>
              <a
                class="w-full text-center text-sm font-medium text-foreground/70 underline underline-offset-4 sm:w-auto"
                href={primaryCta.href}>{primaryCta.label}</a
              >
            </Button>
            <Button size="lg" variant="outline" asChild>
              <a
                class="w-full text-center text-sm font-medium text-foreground/70 underline underline-offset-4 sm:w-auto"
                href={secondaryCta.href}
              >
                {secondaryCta.label}
              </a>
            </Button>
          </div>
        </div>

        <aside
          data-reveal
          data-reveal-delay="120"
          class="rounded-[1rem] border border-black/5 bg-white/90 p-5 backdrop-blur-xl shadow-[0_18px_44px_rgba(18,22,14,0.05)] sm:p-6 lg:ml-8"
        >
          <p class="section-kicker">{proof.label}</p>
          <h2
            class="mt-4 text-lg font-semibold leading-tight tracking-[-0.04em] text-balance sm:text-xl"
          >
            {proof.title}
          </h2>
          <p class="mt-4 text-sm leading-7 text-muted-foreground">
            {proof.description}
          </p>
        </aside>
      </div>
    </div>
  </div>
</section>
