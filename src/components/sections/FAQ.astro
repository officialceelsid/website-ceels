---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  items: readonly FAQItem[];
}

const { title, description, items } = Astro.props;
---

<section id="faq" class="py-14 md:py-24">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title">{title}</h2>
      <p class="mt-4 text-base leading-7 text-muted-foreground sm:mt-5 sm:text-lg sm:leading-8">{description}</p>
    </div>

    <div class="mx-auto mt-10 grid max-w-4xl gap-3 md:mt-16 md:gap-4">
      {items.map((item, index) => (
        <details data-reveal data-reveal-delay={String(index * 60)} class="soft-card rounded-[1rem] p-5 sm:p-6 md:p-7">
          <summary class="cursor-pointer list-none pr-8 text-left text-base font-semibold sm:text-lg">
            {item.question}
          </summary>
          <p class="mt-4 text-sm leading-6 text-muted-foreground sm:mt-5 sm:text-base">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
