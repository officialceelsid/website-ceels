---
interface ServiceItem {
  title: string;
  description: string;
  points: readonly string[];
}

interface PackageTeaser {
  name: string;
  price: string;
  promo: string;
}

interface Props {
  title: string;
  description: string;
  items: readonly ServiceItem[];
  packageTeasers?: readonly PackageTeaser[];
}

const { title, description, items, packageTeasers = [] } = Astro.props;

const serviceImages = ["/services.webp", "/hero.webp", "/project.webp"];
---

<section id="services" class="page-shell">
  <div class="site-stack">
    <div class="panel-light panel-outline section-frame">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <p class="display-eyebrow text-primary/72">Layanan Inti</p>
          <h2 class="section-title mt-4 max-w-[9ch] text-primary">{title}</h2>
          <p class="section-copy mt-5 max-w-2xl text-primary/78">{description}</p>
        </div>
        <a href="/services" class="section-link shrink-0">
          <span>Lihat semua layanan</span>
          <span class="arrow-chip">↗</span>
        </a>
      </div>

      <div class="mt-10 grid gap-5 lg:mt-14 lg:grid-cols-3">
        {items.slice(0, 3).map((service, index) => (
          <article data-reveal data-reveal-delay={String(index * 90)} class="relative overflow-hidden rounded-[2rem] border border-primary/12 bg-primary text-white shadow-[0_18px_40px_rgba(26,31,25,0.16)]">
            <img src={serviceImages[index % serviceImages.length]} alt={service.title} class="absolute inset-0 h-full w-full object-cover opacity-70" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/68 via-black/22 to-transparent"></div>
            <div class="relative flex min-h-[380px] flex-col justify-between p-6 md:min-h-[420px] md:p-7">
              <div>
                <p class="font-display text-4xl uppercase leading-[0.9] tracking-[-0.04em] md:text-5xl">{service.title}</p>
                <p class="mt-4 max-w-xs text-sm leading-7 text-white/88 md:text-base">{service.description}</p>
              </div>
              <div class="flex items-center justify-between gap-4">
                <span class="text-base font-medium text-white">Pelajari lebih lanjut</span>
                <span class="arrow-chip arrow-chip-accent shrink-0">↗</span>
              </div>
            </div>
          </article>
        ))}
      </div>

      {packageTeasers.length > 0 && (
        <div class="mt-8 rounded-[2rem] border border-primary/12 bg-primary/4 p-5 md:mt-10 md:p-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div class="max-w-2xl">
              <p class="display-eyebrow text-primary/68">Paket Awal</p>
              <p class="mt-2 text-base leading-7 text-primary/78 md:text-lg">
                Untuk kebutuhan yang lebih ringan, Anda juga bisa mulai dari beberapa paket dasar berikut.
              </p>
            </div>
            <a href="/services#packages" class="section-link shrink-0 text-base">
              <span>Lihat semua paket</span>
              <span class="arrow-chip h-9 w-9 text-base">↗</span>
            </a>
          </div>

          <div class="mt-6 grid gap-3 md:grid-cols-3">
            {packageTeasers.slice(0, 3).map((pkg, index) => (
              <article data-reveal data-reveal-delay={String(index * 70)} class="soft-card rounded-[1.5rem] p-4 md:p-5">
                <p class="font-display text-[1.8rem] uppercase leading-[0.92] tracking-[-0.04em] text-primary">{pkg.name}</p>
                <p class="mt-2 text-sm font-semibold text-primary">{pkg.price}</p>
                <p class="mt-3 text-sm leading-6 text-primary/68">{pkg.promo}</p>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
