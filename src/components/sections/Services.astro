---
interface ServiceItem {
  title: string;
  description: string;
  points: readonly string[];
}

interface Props {
  title: string;
  description: string;
  items: readonly ServiceItem[];
}

const { title, description, items } = Astro.props;
---

<section id="services" class="py-14 md:py-24">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title">{title}</h2>
      <p class="mt-4 text-base leading-7 text-muted-foreground sm:mt-5 sm:text-lg sm:leading-8">
        {description}
      </p>
    </div>
    <div class="mt-10 grid gap-4 md:mt-16 md:grid-cols-2 lg:grid-cols-3 lg:gap-6">
      {items.map((service, index) => (
        <div data-reveal data-reveal-delay={String(index * 70)} class="soft-card group rounded-[1rem] p-5 sm:p-6 md:p-7 hover:-translate-y-1 hover:border-white/80 hover:shadow-[0_22px_55px_rgba(125,161,62,0.12)]">
          <div class="inline-flex rounded-lg border border-primary/20 bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-foreground/80">
            Layanan
          </div>
          <h3 class="mt-4 text-lg font-semibold tracking-[-0.03em] sm:mt-5 sm:text-xl">{service.title}</h3>
          <p class="mt-2.5 text-sm leading-6 text-muted-foreground sm:mt-3 sm:text-base">{service.description}</p>
          <ul class="mt-5 space-y-2 text-sm text-muted-foreground sm:mt-6 sm:space-y-2.5">
            {service.points.map((point) => (
              <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-primary"></span><span>{point}</span></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
