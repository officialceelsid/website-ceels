---
interface ArchiveItem {
  name: string;
  category: string;
  summary: string;
  outcome: string;
  tags: readonly string[];
}

interface Props {
  title: string;
  description: string;
  items: readonly ArchiveItem[];
}

const { title, description, items } = Astro.props;

const archiveImages = ["/project.webp", "/services.webp", "/hero.webp"];
---

<section class="page-shell">
  <div class="site-stack">
    <div class="panel-dark section-frame">
      <div class="max-w-2xl">
        <p class="display-eyebrow text-white/72">Arsip</p>
        <h2 class="section-title mt-4 text-white">{title}</h2>
        <p class="section-copy mt-5 text-white/78">{description}</p>
      </div>

      <div class="mt-12 border-t border-white/16 pt-4">
        {items.map((item, index) => (
          <article data-reveal data-reveal-delay={String(index * 90)} class="grid items-center gap-4 border-b border-white/16 py-5 md:grid-cols-[1.35fr_0.65fr_0.65fr_130px] md:gap-6 md:py-6">
            <div>
              <h3 class="font-display text-3xl uppercase leading-none tracking-[-0.04em] text-white md:text-4xl">{item.name}</h3>
              <p class="mt-2 text-sm text-white/68">{item.summary}</p>
            </div>
            <p class="text-sm uppercase tracking-[0.08em] text-white/60">2024</p>
            <p class="text-sm uppercase tracking-[0.08em] text-white/82">{item.category}</p>
            <img src={archiveImages[index % archiveImages.length]} alt={item.name} class="h-20 w-[7.5rem] rounded-[1.25rem] border border-white/12 object-cover" />
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
