---
interface ArchiveItem {
  name: string;
  category: string;
  summary: string;
  outcome: string;
  tags: readonly string[];
}

interface Props {
  title: string;
  description: string;
  items: readonly ArchiveItem[];
}

const { title, description, items } = Astro.props;
---

<section class="py-20 md:py-32">
  <div class="container mx-auto px-4">
    <div class="max-w-2xl">
      <p class="section-kicker">Arsip</p>
      <h2 class="mt-3 section-title">{title}</h2>
      <p class="mt-4 text-lg text-muted-foreground">{description}</p>
    </div>

    <div class="mt-12 grid gap-6">
      {items.map((item, index) => (
        <article data-reveal data-reveal-delay={String(index * 90)} class={`soft-card rounded-[1.25rem] p-6 md:p-8 ${index === 0 ? "lg:grid lg:grid-cols-[1fr_1.2fr] lg:gap-8" : ""}`}>
          <div class={`rounded-[1rem] border border-white/60 bg-[linear-gradient(135deg,rgba(255,255,255,0.68),rgba(226,242,191,0.48))] p-6 min-h-[240px] flex flex-col justify-between ${index === 0 ? "mb-6 lg:mb-0" : "mb-6"}`}>
            <div>
              <p class="section-kicker">{item.category}</p>
              <h3 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.04em] md:text-3xl">{item.name}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class="rounded-lg border border-white/65 bg-white/45 px-3 py-1.5 text-xs text-foreground/75">{tag}</span>
              ))}
            </div>
          </div>

          <div>
            <p class="text-base leading-7 text-muted-foreground">{item.summary}</p>
            <p class="mt-6 inline-flex rounded-lg border border-white/65 bg-white/45 px-4 py-2 text-sm text-foreground/75">{item.outcome}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
