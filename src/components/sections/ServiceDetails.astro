---
interface Offering {
  title: string;
  summary: string;
  deliverables: readonly string[];
  idealFor: string;
}

interface Props {
  offerings: readonly Offering[];
  approach: {
    title: string;
    description: string;
    items: readonly {
      title: string;
      text: string;
    }[];
  };
}

const { offerings, approach } = Astro.props;
---

<section class="page-shell">
  <div class="site-stack">
    <div class="grid gap-5">
      {offerings.map((offering, index) => (
        <article data-reveal data-reveal-delay={String(index * 90)} class={`panel-dark section-frame grid gap-6 lg:grid-cols-[0.75fr_1.25fr] ${index % 2 === 1 ? "lg:grid-cols-[1.25fr_0.75fr]" : ""}`}>
          <div class={`rounded-[2rem] border border-white/14 bg-white/4 p-6 md:p-8 ${index % 2 === 1 ? "lg:order-2" : ""}`}>
            <p class="display-eyebrow text-accent">Layanan</p>
            <h2 class="section-title mt-4 text-white">{offering.title}</h2>
            <p class="mt-5 text-white/72">Cocok untuk: {offering.idealFor}</p>
          </div>

          <div class={index % 2 === 1 ? "lg:order-1" : ""}>
            <p class="text-base leading-8 text-white/78 md:text-lg">{offering.summary}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              {offering.deliverables.map((item) => (
                <span class="rounded-full border border-white/18 bg-white/6 px-4 py-2 text-sm text-white/84">{item}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div data-reveal class="panel-light panel-outline section-frame">
      <div class="max-w-2xl">
        <p class="display-eyebrow text-primary/72">Pendekatan</p>
        <h2 class="section-title mt-4 text-primary">{approach.title}</h2>
        <p class="section-copy mt-5 text-primary/78">{approach.description}</p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {approach.items.map((item, index) => (
          <div data-reveal data-reveal-delay={String(index * 80)} class="soft-card rounded-[1.8rem] p-6">
            <h3 class="font-display text-3xl uppercase leading-[0.95] tracking-[-0.04em] text-primary">{item.title}</h3>
            <p class="mt-4 text-primary/76">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
