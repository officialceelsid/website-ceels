---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  logos: readonly string[];
}

const { eyebrow, title, description, logos } = Astro.props;
---

<section class="py-10 md:py-14">
  <div class="container mx-auto px-4">
    <div class="soft-surface grain-texture rounded-[1.25rem] px-6 py-8 md:px-8 md:py-10">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div>
          <p class="section-kicker">{eyebrow}</p>
          <h2 class="mt-3 max-w-xl text-2xl font-semibold leading-tight tracking-[-0.04em] md:text-3xl">{title}</h2>
          <p class="mt-4 max-w-xl text-muted-foreground">{description}</p>
        </div>

        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {logos.map((logo, index) => (
            <div class="rounded-lg border border-white/60 bg-white/45 px-4 py-4 text-center text-sm font-medium text-foreground/80 backdrop-blur-sm">
              {logo}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
