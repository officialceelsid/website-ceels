---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  steps: readonly Step[];
}

const { title, description, steps } = Astro.props;
---

<section id="process" class="section-wash py-18 md:py-36">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title">{title}</h2>
      <p class="mt-4 text-base leading-7 text-muted-foreground sm:mt-5 sm:text-lg sm:leading-8">{description}</p>
    </div>

    <div class="mt-12 grid gap-4 md:mt-20 md:grid-cols-2 xl:grid-cols-4 xl:gap-7">
      {steps.map((step, index) => (
        <article data-reveal data-reveal-delay={String(index * 80)} class="soft-card rounded-[1rem] p-5 sm:p-6 md:p-7">
          <p class="section-kicker text-primary">{step.number}</p>
          <h3 class="mt-4 text-lg font-semibold tracking-[-0.03em] sm:mt-5 sm:text-xl">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-muted-foreground sm:mt-4 sm:text-base">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
