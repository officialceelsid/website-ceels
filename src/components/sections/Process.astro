---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  steps: readonly Step[];
}

const { title, description, steps } = Astro.props;
---

<section id="process" class="page-shell">
  <div class="site-stack">
    <div class="panel-light section-frame">
      <div class="max-w-3xl">
        <p class="display-eyebrow text-primary/72">Proses</p>
        <h2 class="section-title mt-4 max-w-[10ch] text-primary">{title}</h2>
        <p class="section-copy mt-5 max-w-2xl text-primary/78">{description}</p>
      </div>

      <div class="mt-10 grid gap-4 md:mt-14 md:grid-cols-2 xl:grid-cols-4">
        {steps.map((step, index) => (
          <article data-reveal data-reveal-delay={String(index * 80)} class="soft-card rounded-[2rem] p-6 md:p-7">
            <p class="font-display text-5xl uppercase leading-none tracking-[-0.04em] text-primary/28 md:text-6xl">{step.number}</p>
            <h3 class="font-display mt-5 text-3xl uppercase leading-[0.95] tracking-[-0.04em] text-primary">{step.title}</h3>
            <p class="mt-4 text-sm leading-7 text-primary/75 md:text-base">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
