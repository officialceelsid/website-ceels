---
interface TestimonialItem {
  quote: string;
  name: string;
  role: string;
}

interface Props {
  title: string;
  description: string;
  featured: {
    quote: string;
    name: string;
    role: string;
  };
  items: readonly TestimonialItem[];
}

const { title, description, featured, items } = Astro.props;
---

<section class="section-wash py-18 md:py-36">
  <div class="container mx-auto px-4">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:gap-14">
      <div>
        <p class="section-kicker">Suara klien</p>
        <h2 class="mt-3 section-title">{title}</h2>
        <p class="mt-4 max-w-xl text-base leading-7 text-muted-foreground sm:mt-5 sm:text-lg sm:leading-8">{description}</p>
      </div>
      <blockquote data-reveal class="soft-card rounded-[1.25rem] p-5 sm:p-8 md:p-10 lg:mt-8">
        <p class="text-lg leading-8 tracking-[-0.02em] text-foreground sm:text-xl sm:leading-9 md:text-2xl md:leading-10">“{featured.quote}”</p>
        <footer class="mt-7 border-t border-white/60 pt-4 sm:mt-10 sm:pt-5">
          <p class="font-semibold">{featured.name}</p>
          <p class="text-sm text-muted-foreground">{featured.role}</p>
        </footer>
      </blockquote>
    </div>

    <div class="mt-10 grid gap-4 md:mt-16 lg:grid-cols-3 lg:gap-7">
      {items.map((item, index) => (
        <blockquote data-reveal data-reveal-delay={String(index * 80)} class={`soft-card rounded-[1rem] p-5 sm:p-6 md:p-7 ${index === 1 ? "lg:mt-10" : index === 2 ? "lg:mt-20" : ""}`}>
          <p class="text-sm leading-6 text-foreground sm:text-base sm:leading-7">“{item.quote}”</p>
          <footer class="mt-6 border-t border-white/60 pt-4 sm:mt-7">
            <p class="font-semibold">{item.name}</p>
            <p class="text-sm text-muted-foreground">{item.role}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
