---
interface TestimonialItem {
  quote: string;
  name: string;
  role: string;
}

interface Props {
  title: string;
  description: string;
  featured: {
    quote: string;
    name: string;
    role: string;
  };
  items: readonly TestimonialItem[];
}

const { title, description, featured, items } = Astro.props;
---

<section class="page-shell">
  <div class="site-stack">
    <div class="panel-light panel-outline section-frame">
      <div class="mx-auto max-w-4xl text-center">
        <p class="display-eyebrow text-primary/72">Testimoni</p>
        <h2 class="section-title mt-4 text-primary">{title}</h2>
        <p class="section-copy mx-auto mt-5 max-w-2xl text-primary/78">{description}</p>
      </div>

      <div class="mt-12 grid gap-8 lg:mt-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-14">
        <div data-reveal class="px-2 md:px-4 lg:px-8">
          <p class="display-eyebrow text-primary/55">Klien Pilihan</p>
          <blockquote class="mt-6 text-2xl leading-[1.45] tracking-[-0.03em] text-primary md:text-[2.1rem]">
            “{featured.quote}”
          </blockquote>
          <footer class="mt-7">
            <p class="text-lg font-semibold text-primary">{featured.name}</p>
            <p class="text-primary/68">{featured.role}</p>
          </footer>
          <a href="#contact" class="section-link mt-10 inline-flex">
            <span>Baca ceritanya</span>
            <span class="arrow-chip">↗</span>
          </a>
        </div>

        <div data-reveal data-reveal-delay="120" class="relative mx-auto w-full max-w-[560px]">
          <div class="rounded-[2rem] border border-primary/20 bg-white p-3 shadow-[0_22px_48px_rgba(26,31,25,0.12)]">
            <img src="/testimonials.webp" alt={featured.name} class="aspect-[1.16/1] w-full rounded-[1.6rem] object-cover object-center" />
            <div class="mt-4 flex items-end justify-between gap-4 px-2 pb-1">
              <div>
                <p class="text-xl font-semibold text-primary">{items[0]?.name ?? featured.name}</p>
                <p class="text-primary/68">{items[0]?.role ?? featured.role}</p>
              </div>
              <span class="arrow-chip arrow-chip-accent">▶</span>
            </div>
          </div>
          <div class="absolute -right-2 top-6 text-7xl leading-none text-accent md:text-8xl">⌝</div>
        </div>
      </div>

      <div class="mt-10 flex justify-center gap-2">
        <span class="h-2 w-[4.5rem] rounded-full bg-primary"></span>
        <span class="h-2 w-4 rounded-full bg-primary/12"></span>
        <span class="h-2 w-4 rounded-full bg-primary/12"></span>
      </div>
    </div>
  </div>
</section>
