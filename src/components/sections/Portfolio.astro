---
interface WorkItem {
  name: string;
  category: string;
  summary: string;
}

interface Props {
  title: string;
  description: string;
  items: readonly WorkItem[];
}

const { title, description, items } = Astro.props;

const featured = items[0];
const archive = items.slice(1);
const archiveImages = ["/project.webp", "/services.webp", "/hero.webp"];
---

<section id="work" class="page-shell">
  <div class="site-stack">
    <div class="panel-dark section-frame">
      <div class="grid gap-10 xl:grid-cols-[1.06fr_0.94fr] xl:items-start">
        <div data-reveal class="rounded-[2rem] border border-white/14 bg-white/3 p-3 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.05)]">
          <img src="/project.webp" alt={featured.name} class="w-full rounded-[1.65rem] object-cover" />
        </div>

        <div data-reveal data-reveal-delay="100" class="xl:pt-2">
          <p class="display-eyebrow text-white/75">Pilihan karya</p>
          <p class="mt-2 text-sm uppercase tracking-[0.08em] text-accent">Nov 2024 • {featured.category}</p>
          <h2 class="section-title mt-4 max-w-[9ch] text-white">{title}</h2>
          <p class="mt-6 max-w-xl text-base leading-8 text-white/78 md:text-lg">{description}</p>
          <h3 class="font-display mt-8 text-5xl uppercase leading-[0.9] tracking-[-0.05em] text-white md:text-6xl">{featured.name}</h3>
          <p class="mt-5 max-w-lg text-base leading-8 text-white/78">{featured.summary}</p>
          <a href="/works" class="section-link mt-10 text-white inline-flex">
            <span>Lihat proyek</span>
            <span class="arrow-chip border-white/30 text-white">↗</span>
          </a>
        </div>
      </div>

      <div class="mt-12 border-t border-white/16 pt-6 md:mt-14 md:pt-8">
        {archive.map((item, index) => (
          <article data-reveal data-reveal-delay={String(index * 80)} class="grid items-center gap-4 border-b border-white/16 py-5 md:grid-cols-[1.4fr_0.6fr_0.65fr_120px] md:gap-6 md:py-6">
            <div>
              <h3 class="font-display text-3xl uppercase leading-none tracking-[-0.04em] text-white md:text-4xl">{item.name}</h3>
            </div>
            <p class="text-sm uppercase tracking-[0.08em] text-white/60">2024</p>
            <p class="text-sm uppercase tracking-[0.08em] text-white/78">{item.category}</p>
            <img src={archiveImages[index % archiveImages.length]} alt={item.name} class="h-20 w-28 rounded-[1.25rem] border border-white/12 object-cover" />
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
