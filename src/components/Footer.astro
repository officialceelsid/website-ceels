---
import { siteConfig } from "@/config/site";

const currentYear = new Date().getFullYear();
---

<footer class="page-shell pt-0">
  <div class="site-stack">
    <div class="panel-light px-6 pb-8 pt-0 md:px-12 md:pb-10">
      <div class="flex flex-col gap-5 border-t border-primary/20 pt-6 text-sm text-primary/78 md:flex-row md:items-center md:justify-between md:pt-8">
        <div class="flex items-center gap-3">
          <img src="/logo.svg" alt={siteConfig.name} class="h-7 w-7" />
          <p>&copy; {currentYear} {siteConfig.name}. Seluruh hak cipta dilindungi.</p>
        </div>
        <div class="flex flex-wrap items-center gap-3 md:gap-5">
          <span>Syarat & Ketentuan</span>
          <span class="hidden text-primary/35 md:inline">•</span>
          <span>Kebijakan Privasi</span>
        </div>
      </div>
    </div>
  </div>
</footer>
