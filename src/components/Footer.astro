---
import { siteConfig } from "@/config/site";
import { mainNavigation } from "@/content/site";

const currentYear = new Date().getFullYear();
---

<footer class="section-wash border-t border-white/50 bg-transparent">
  <div class="container mx-auto px-4 py-12">
    <div class="soft-surface grain-texture rounded-[1.25rem] px-6 py-8 md:px-8 md:py-10">
      <div class="grid gap-8 md:grid-cols-4">
        <div class="md:col-span-2">
          <a href="/" class="brand-lockup text-xl font-semibold tracking-[-0.03em] text-foreground">
            <img src="/logo.svg" alt={siteConfig.name} class="brand-mark" />
            <span>{siteConfig.name}</span>
          </a>
          <p class="mt-4 max-w-md text-sm text-muted-foreground">
            {siteConfig.description}
          </p>
        </div>

        <div>
          <h3 class="font-semibold">Jelajahi</h3>
          <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
            {mainNavigation.map((link) => (
              <li><a href={link.href} class="hover:text-foreground">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="font-semibold">Kontak</h3>
          <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
            <li><a href={`mailto:${siteConfig.contact.email}`} class="hover:text-foreground">{siteConfig.contact.email}</a></li>
            <li><a href={`tel:${siteConfig.contact.phone}`} class="hover:text-foreground">{siteConfig.contact.phone}</a></li>
            <li><a href={`https://wa.me/${siteConfig.contact.whatsapp}`} class="hover:text-foreground">WhatsApp</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-white/50 pt-8 md:flex-row">
        <p class="text-sm text-muted-foreground">
          &copy; {currentYear} {siteConfig.name}. Seluruh hak cipta dilindungi.
        </p>
        <div class="flex gap-4">
          <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground">
            GitHub
          </a>
          <a href={siteConfig.links.linkedin} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground">
            LinkedIn
          </a>
          <a href={siteConfig.links.instagram} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground">
            Instagram
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
